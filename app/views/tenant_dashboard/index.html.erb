<div class="mb-8">
  <h1 class="text-4xl font-black text-white tracking-tight">
    My <span class="text-indigo-500">Dashboard</span> 🏠
  </h1>
  <p class="text-slate-400 mt-2">Welcome back! Here is your current residency overview.</p>
</div>

<% if @latest_lease %>
  <% balance_cents = @latest_lease.balance_due_cents || (@latest_lease.rent_amount.to_f * 100).to_i %>
  <% balance_amount = balance_cents / 100.0 %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

    <div class="relative overflow-hidden bg-slate-900/50 border border-white/10 p-6 rounded-[2rem] shadow-2xl backdrop-blur-md">
      <h2 class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-2">Monthly Rent</h2>
      <p class="text-3xl font-black text-white">
        ₹<%= number_with_delimiter(@latest_lease.rent_amount) %>
      </p>
      <p class="text-slate-500 text-xs mt-1 italic">Due every month</p>
    </div>

    <div class="relative overflow-hidden bg-slate-900/50 border border-white/10 p-6 rounded-[2rem] shadow-2xl backdrop-blur-md">
      <h2 class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-2">Balance Due</h2>

      <% if balance_cents <= 0 %>
        <p class="text-3xl font-black text-emerald-400">₹0</p>
        <span class="inline-block mt-4 bg-emerald-500/10 text-emerald-400 border border-emerald-500/30 px-4 py-1.5 rounded-full text-xs font-black uppercase">
          ✅ Rent Paid
        </span>
      <% else %>
        <p class="text-3xl font-black text-rose-400">
          ₹<%= number_with_delimiter(balance_amount) %>
        </p>

        <% if @latest_lease.due_date < Date.today %>
          <span class="inline-block mt-4 bg-rose-500/10 text-rose-400 border border-rose-500/30 px-4 py-1.5 rounded-full text-xs font-black uppercase animate-pulse">
            ⚠️ Overdue
          </span>
        <% elsif @latest_lease.due_date == Date.today %>
          <span class="inline-block mt-4 bg-amber-500/10 text-amber-400 border border-amber-500/30 px-4 py-1.5 rounded-full text-xs font-black uppercase">
            ⏰ Due Today
          </span>
        <% else %>
          <span class="inline-block mt-4 bg-indigo-500/10 text-indigo-400 border border-indigo-500/30 px-4 py-1.5 rounded-full text-xs font-black uppercase">
            Pending Payment
          </span>
        <% end %>
      <% end %>
    </div>

    <div class="relative overflow-hidden bg-slate-900/50 border border-white/10 p-6 rounded-[2rem] shadow-2xl backdrop-blur-md">
      <h2 class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-2">Next Due Date</h2>

      <p class="text-2xl font-bold text-white">
        <%= @latest_lease.due_date.strftime("%B %d, %Y") %>
      </p>

      <% if balance_cents <= 0 %>
        <div class="flex items-center gap-2 mt-4 text-emerald-400">
          <span class="text-2xl">🎉</span>
          <p class="font-bold">Clear Balance</p>
        </div>
      <% else %>
        <p class="text-slate-500 text-xs mt-4 italic">Please complete your rent payment.</p>
      <% end %>
    </div>

  </div>

  <div class="mb-12">
    <% if balance_cents > 0 %>
      <%= link_to new_v1_payment_path(lease_id: @latest_lease.id),
        class: "inline-flex items-center gap-3 bg-gradient-to-r from-pink-500 via-purple-500 to-indigo-500 text-white px-10 py-4 rounded-2xl font-black shadow-lg shadow-purple-500/30 hover:scale-105 transition active:scale-95" do %>
        <span class="text-xl">💳</span> Pay Rent Now
      <% end %>
    <% else %>
      <div class="inline-flex items-center gap-3 bg-gradient-to-r from-emerald-500 to-green-600 text-white px-10 py-4 rounded-2xl font-black shadow-lg shadow-emerald-500/30">
        <span class="text-xl">✅</span> Rent Already Paid
      </div>
    <% end %>
  </div>

<% else %>
  <div class="bg-slate-900/50 border border-dashed border-white/10 p-12 rounded-[2rem] text-center">
    <p class="text-slate-500 text-lg italic">No active lease assigned to your profile yet.</p>
  </div>
<% end %>