<div class="mb-8">
  <h1 class="text-4xl font-black text-white tracking-tight">
    My <span class="text-indigo-500">Dashboard</span> 🏠
  </h1>
  <p class="text-slate-400 mt-2">Welcome back! Here is your current residency overview.</p>
</div>

<% if @latest_lease %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

    <div class="relative overflow-hidden bg-slate-900/50 border border-white/10 p-6 rounded-[2rem] shadow-2xl backdrop-blur-md">
      <div class="absolute -right-6 -top-6 w-24 h-24 bg-indigo-600/10 blur-2xl rounded-full"></div>
      <h2 class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-2">Monthly Rent</h2>
      <p class="text-3xl font-black text-white">
        ₹<%= number_with_delimiter(@latest_lease.rent_amount) %>
      </p>
      <p class="text-slate-500 text-xs mt-1 italic">Due every month</p>
    </div>

    <div class="relative overflow-hidden bg-slate-900/50 border border-white/10 p-6 rounded-[2rem] shadow-2xl backdrop-blur-md">
      <h2 class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-2">Next Due Date</h2>
    
      <p class="text-2xl font-bold text-white">
        <%= @latest_lease.due_date.strftime("%B %d, %Y") %>
      </p>
    
      <div class="mt-4">
        <% if @latest_lease.due_date < Date.today %>
          <span class="bg-rose-500/10 text-rose-400 border border-rose-500/30 px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-tighter animate-pulse">
            ⚠️ Overdue
          </span>
        <% elsif @latest_lease.due_date == Date.today %>
          <span class="bg-amber-500/10 text-amber-400 border border-amber-500/30 px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-tighter">
            ⏰ Due Today
          </span>
        <% else %>
          <span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/30 px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-tighter">
            ✅ On Time
          </span>
        <% end %>
      </div>
    </div>

    <div class="relative overflow-hidden bg-slate-900/50 border border-white/10 p-6 rounded-[2rem] shadow-2xl backdrop-blur-md">
      <h2 class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-2">Accumulated Fees</h2>

      <% if @latest_lease.late_fee.to_i > 0 %>
        <p class="text-3xl font-black text-rose-500">
          ₹<%= number_with_delimiter(@latest_lease.late_fee) %>
        </p>
        <p class="text-rose-400/50 text-[10px] uppercase font-bold mt-1">Please pay immediately</p>
      <% else %>
        <div class="flex items-center gap-2 mt-2 text-emerald-400">
          <span class="text-2xl">🎉</span>
          <p class="font-bold">Clear Balance</p>
        </div>
      <% end %>
    </div>

  </div>

  <div class="mb-12">
    <%= link_to new_v1_payment_path(lease_id: @latest_lease.id),
      class: "inline-flex items-center gap-3 bg-gradient-to-r from-pink-500 via-purple-500 to-indigo-500 text-white px-10 py-4 rounded-2xl font-black shadow-lg shadow-purple-500/30 hover:scale-105 transition active:scale-95" do %>
      <span class="text-xl">💳</span> Pay Rent Now
    <% end %>
  </div>

<% else %>
  <div class="bg-slate-900/50 border border-dashed border-white/10 p-12 rounded-[2rem] text-center">
    <p class="text-slate-500 text-lg italic">No active lease assigned to your profile yet.</p>
  </div>
<% end %>

<div class="flex items-center gap-3 mb-6">
  <div class="w-2 h-8 bg-indigo-500 rounded-full"></div>
  <h2 class="text-2xl font-bold text-white">Payment History</h2>
</div>

<div class="overflow-hidden bg-slate-900/40 border border-white/5 rounded-3xl shadow-2xl">
  <table class="w-full text-left">
    <thead class="bg-white/5 text-slate-400 uppercase text-[10px] font-black tracking-[0.2em]">
      <tr>
        <th class="px-6 py-4">Transaction Date</th>
        <th class="px-6 py-4">Amount</th>
        <th class="px-6 py-4">Status</th>
      </tr>
    </thead>

    <tbody class="divide-y divide-white/5">
      <% @payments.each do |payment| %>
        <tr class="group hover:bg-white/5 transition">
          <td class="px-6 py-5 text-slate-300">
            <%= payment.payment_date.strftime("%b %d, %Y") %>
          </td>

          <td class="px-6 py-5">
            <span class="text-white font-black">₹<%= number_with_delimiter(payment.amount) %></span>
          </td>

          <td class="px-6 py-5">
            <% if payment.status == "paid" %>
              <div class="flex items-center gap-2 text-emerald-400 text-sm font-bold">
                <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
                Completed
              </div>
            <% else %>
              <div class="flex items-center gap-2 text-amber-400 text-sm font-bold">
                <span class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-pulse"></span>
                Pending
              </div>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>