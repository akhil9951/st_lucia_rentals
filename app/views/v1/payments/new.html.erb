<div class="min-h-screen bg-gradient-to-br from-slate-950 via-indigo-950 to-black p-6 flex items-center justify-center text-white">
  
  <div class="w-full max-w-md relative overflow-hidden rounded-3xl p-8 
              bg-slate-900/50 border border-indigo-500/30 shadow-2xl backdrop-blur-md">
    
    <div class="absolute -top-20 -left-20 w-48 h-48 bg-purple-600 blur-3xl opacity-20 rounded-full"></div>
    <div class="absolute -bottom-20 -right-20 w-48 h-48 bg-blue-600 blur-3xl opacity-20 rounded-full"></div>

    <div class="relative z-10">
      <h1 class="text-3xl font-extrabold mb-2 bg-gradient-to-r from-pink-400 to-blue-400 bg-clip-text text-transparent">
        New Payment 💸
      </h1>
      <p class="text-gray-400 mb-8 text-sm">Fill in the details to complete your transaction.</p>

      <%= form_with model: [:v1, @payment], class: "space-y-6" do |f| %>
        <%= f.hidden_field :lease_id, value: params[:lease_id] %>

        <div>
          <%= f.label :tenant_id, class: "block text-sm font-medium text-gray-300 mb-2" %>
          <%= f.number_field :tenant_id, 
              class: "w-full bg-slate-800/50 border border-indigo-500/20 rounded-xl px-4 py-3 text-white 
                      focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition" %>
        </div>

        <div>
          <%= f.label :amount, "Amount (₹)", class: "block text-sm font-medium text-gray-300 mb-2" %>
          <%= f.number_field :amount, 
              placeholder: "e.g. 5000",
              class: "w-full bg-slate-800/50 border border-indigo-500/20 rounded-xl px-4 py-3 text-white 
                      focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition" %>
        </div>

        <div>
          <%= f.label :payment_date, class: "block text-sm font-medium text-gray-300 mb-2" %>
          <%= f.date_field :payment_date, 
              class: "w-full bg-slate-800/50 border border-indigo-500/20 rounded-xl px-4 py-3 text-white 
                      focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition [color-scheme:dark]" %>
        </div>

        <div class="pt-4">
          <%= f.submit "Confirm Payment", 
              class: "w-full py-4 rounded-2xl font-bold text-lg
                      bg-gradient-to-r from-pink-500 via-purple-500 to-blue-500
                      shadow-lg shadow-purple-500/30
                      hover:scale-[1.02] active:scale-95 transition-all cursor-pointer" %>
        </div>

        <div class="text-center mt-6">
          <%= link_to "Cancel", :back, class: "text-gray-500 hover:text-gray-300 text-sm transition" %>
        </div>
      <% end %>
    </div>
  </div>
</div>