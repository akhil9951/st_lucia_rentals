<div class="max-w-4xl mx-auto px-4">
  
  <div class="mb-8">
    <%= link_to v1_leases_path, class: "group flex items-center gap-2 text-slate-400 hover:text-white transition" do %>
      <span class="text-lg group-hover:-translate-x-1 transition-transform">←</span>
      Back to Leases
    <% end %>
  </div>

  <div class="relative overflow-hidden bg-slate-900/50 border border-white/10 backdrop-blur-xl rounded-[2.5rem] p-8 shadow-2xl mb-10">
    <div class="absolute -top-24 -right-24 w-64 h-64 bg-indigo-500/10 blur-[100px] rounded-full"></div>
    
    <div class="relative z-10">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-3xl font-black text-white tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-400">
          Lease Details
        </h2>
        <span class="px-4 py-1.5 bg-indigo-500/20 text-indigo-400 text-xs font-bold uppercase tracking-widest rounded-full border border-indigo-500/30">
          Active Contract
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="space-y-1">
          <p class="text-slate-500 text-xs font-bold uppercase tracking-widest">Tenant</p>
          <p class="text-white text-xl font-bold"><%= @lease.tenant.name %></p>
        </div>

        <div class="space-y-1">
          <p class="text-slate-500 text-xs font-bold uppercase tracking-widest">Property Unit</p>
          <div class="flex items-center gap-2">
            <span class="text-indigo-400">🏢</span>
            <p class="text-white text-xl font-bold"><%= @lease.unit.name %></p>
          </div>
        </div>

        <div class="space-y-1">
          <p class="text-slate-500 text-xs font-bold uppercase tracking-widest">Agreed Rent</p>
          <p class="text-emerald-400 text-2xl font-black">₹<%= number_with_delimiter(@lease.rent_amount) %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
    <h3 class="text-xl font-bold text-white flex items-center gap-3">
      <span class="text-pink-500 text-2xl">💳</span> Payment History
    </h3>
    
    <%= link_to new_v1_payment_path(lease_id: @lease.id),
        class: "inline-flex items-center gap-2 bg-gradient-to-r from-emerald-500 to-teal-600 text-white px-6 py-2.5 rounded-xl font-bold shadow-lg shadow-emerald-500/20 hover:scale-105 transition active:scale-95 text-sm" do %>
      <span>+</span> Add New Payment
    <% end %>
  </div>

  <div class="space-y-3">
    <% if @lease.payments.any? %>
      <% @lease.payments.each do |p| %>
        <div class="group flex items-center justify-between p-4 bg-slate-900/30 border border-white/5 rounded-2xl hover:bg-slate-900/50 hover:border-emerald-500/30 transition">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-emerald-500/10 rounded-full flex items-center justify-center text-emerald-400">
              ✓
            </div>
            <div>
              <p class="text-white font-bold">₹<%= number_with_delimiter(p.amount) %></p>
              <p class="text-slate-500 text-xs tracking-wide"><%= p.payment_date.strftime("%B %d, %Y") %></p>
            </div>
          </div>
          
          <span class="text-xs font-bold text-slate-600 uppercase group-hover:text-emerald-500/50 transition">Success</span>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-12 bg-slate-900/20 border-2 border-dashed border-white/5 rounded-3xl">
        <p class="text-slate-500 italic">No payments recorded for this lease yet.</p>
      </div>
    <% end %>
  </div>

</div>