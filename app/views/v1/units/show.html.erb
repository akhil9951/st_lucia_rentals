<div class="max-w-5xl mx-auto px-4">

  <div class="mb-8">
    <%= link_to v1_units_path, class: "group inline-flex items-center gap-2 text-slate-400 hover:text-white transition" do %>
      <span class="text-xl group-hover:-translate-x-1 transition-transform">←</span>
      <span class="font-medium">Back to Units</span>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <div class="lg:col-span-1">
      <div class="sticky top-24 bg-slate-900/50 border border-white/10 rounded-[2rem] p-8 shadow-2xl backdrop-blur-xl">
        <div class="w-16 h-16 bg-indigo-500/20 rounded-2xl flex items-center justify-center text-3xl mb-6 shadow-inner">
          🏢
        </div>
        
        <h1 class="text-3xl font-black text-white mb-2"><%= @unit.name %></h1>
        <p class="text-slate-500 text-sm font-bold uppercase tracking-widest mb-8">Primary Asset</p>

        <div class="space-y-6">
          <div class="p-4 bg-slate-950/50 rounded-2xl border border-white/5">
            <p class="text-slate-400 text-xs font-bold uppercase tracking-tighter mb-1">Monthly Rent</p>
            <p class="text-emerald-400 text-3xl font-black">₹<%= number_with_delimiter(@unit.rent_amount) %></p>
          </div>

          <div class="flex flex-col gap-3">
            <%= link_to edit_v1_unit_path(@unit), 
                class: "w-full text-center py-3 bg-white text-slate-950 font-bold rounded-xl hover:bg-indigo-400 hover:text-white transition shadow-lg" do %>
              Edit Unit Details
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="mb-6 flex items-center justify-between">
        <h3 class="text-xl font-bold text-white flex items-center gap-3">
          <span class="text-indigo-500 text-2xl">👥</span> 
          Current Tenants
        </h3>
        <span class="px-3 py-1 bg-white/5 rounded-full text-xs text-slate-400 font-mono">
          <%= @unit.tenants.count %> Registered
        </span>
      </div>

      <div class="space-y-4">
        <% if @unit.tenants.any? %>
          <% @unit.tenants.each do |tenant| %>
            <div class="group flex items-center justify-between p-5 bg-slate-900/30 border border-white/5 rounded-2xl hover:bg-slate-900/50 hover:border-indigo-500/30 transition">
              
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-slate-800 rounded-full flex items-center justify-center text-white font-bold group-hover:bg-indigo-600 transition">
                  <%= tenant.name[0] %>
                </div>
                <div>
                  <p class="text-white font-bold group-hover:text-indigo-400 transition"><%= tenant.name %></p>
                  <p class="text-slate-500 text-xs">Active Resident</p>
                </div>
              </div>

              <%= link_to v1_tenant_path(tenant), class: "p-2 bg-white/5 rounded-lg hover:bg-white/10 transition" do %>
                <span class="text-slate-400 text-sm">View Profile →</span>
              <% end %>

            </div>
          <% end %>
        <% else %>
          <div class="text-center py-16 bg-slate-900/20 border-2 border-dashed border-white/5 rounded-3xl">
            <p class="text-slate-500 italic">No tenants currently assigned to this unit.</p>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>