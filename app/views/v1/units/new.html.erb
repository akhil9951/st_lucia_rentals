<div class="max-w-2xl mx-auto px-4 py-12">
  
  <div class="mb-6">
    <%= link_to v1_units_path, class: "group inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors" do %>
      <span class="text-lg group-hover:-translate-x-1 transition-transform duration-200">←</span>
      <span class="font-medium">Back to Units</span>
    <% end %>
  </div>

  <div class="mb-8">
    <h1 class="text-4xl font-black text-white tracking-tight">
      Add New <span class="text-indigo-500">Unit</span>
    </h1>
    <p class="text-slate-400 mt-2">Initialize a new property asset with specific pricing and status.</p>
  </div>

  <div class="relative overflow-hidden bg-slate-900/50 border border-white/10 backdrop-blur-xl rounded-[2.5rem] p-8 shadow-2xl">
    
    <div class="absolute -top-24 -right-24 w-64 h-64 bg-indigo-500/10 blur-[100px] rounded-full z-0 pointer-events-none"></div>

    <%= form_with model: [:v1, @unit], class: "space-y-6 relative z-10", local: true do |f| %>
      
      <% if @unit.errors.any? %>
        <div class="bg-rose-500/10 border border-rose-500/20 p-5 rounded-2xl mb-6 animate-in fade-in slide-in-from-top-2">
          <div class="flex items-center gap-2 text-rose-400 font-bold mb-2">
            <span class="text-lg">⚠️</span>
            <p><%= pluralize(@unit.errors.count, "error") %> prohibited this unit from being saved:</p>
          </div>
          <ul class="list-disc list-inside text-rose-300/80 text-sm space-y-1 ml-2">
            <% @unit.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="group">
        <%= f.label :name, "Unit Name / Number", class: "block text-sm font-medium text-slate-400 group-focus-within:text-indigo-400 transition-colors mb-2" %>
        <%= f.text_field :name, 
            placeholder: "e.g. Apartment 4B or Sunset Villa",
            required: true,
            class: "w-full px-4 py-3 rounded-xl bg-slate-950/50 border border-white/10 text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all [color-scheme:dark]" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="group">
          <%= f.label :rent_amount, "Monthly Rent", class: "block text-sm font-medium text-slate-400 group-focus-within:text-indigo-400 transition-colors mb-2" %>
          <div class="relative">
            <span class="absolute left-4 top-3 text-slate-500 font-medium">₹</span>
            <%= f.number_field :rent_amount, 
                placeholder: "0.00",
                step: "any",
                required: true,
                class: "w-full pl-10 pr-4 py-3 rounded-xl bg-slate-950/50 border border-white/10 text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all [color-scheme:dark]" %>
          </div>
        </div>

        <div class="group">
          <%= f.label :status, "Unit Availability", class: "block text-sm font-medium text-slate-400 group-focus-within:text-indigo-400 transition-colors mb-2" %>
          <div class="relative">
            <%= f.select :status, 
                Unit.statuses.keys.map { |s| [s.humanize, s] }, 
                { selected: @unit.status || 'vacant' }, 
                { class: "w-full px-4 py-3 rounded-xl bg-slate-950/50 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all [color-scheme:dark] appearance-none cursor-pointer" } %>
            
            <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-500 group-hover:text-indigo-400 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-4 pt-6">
        <%= f.submit "Create Property Unit", 
            data: { disable_with: "Processing..." },
            class: "flex-1 py-4 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 text-white font-extrabold shadow-lg shadow-indigo-500/20 hover:scale-[1.01] hover:brightness-110 active:scale-95 transition-all cursor-pointer" %>
      </div>

    <% end %>
  </div>
</div>