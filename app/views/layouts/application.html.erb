<!DOCTYPE html>
<html class="dark">
  <head>
    <title>St Lucia Rentals</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-slate-950 text-slate-200 min-h-screen selection:bg-purple-500/30 antialiased">

    <!-- Background glow -->
    <div class="fixed inset-0 overflow-hidden -z-10">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-purple-600/20 blur-[120px] rounded-full"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-blue-600/20 blur-[120px] rounded-full"></div>
    </div>

    <!-- NAVBAR -->
    <nav class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/60 backdrop-blur-xl px-8 py-4 flex justify-between items-center">

      <!-- Logo -->
      <div class="flex items-center gap-3">

        <!-- If you want image logo later, uncomment this -->
        <!-- <%= image_tag "mother_marry.jpg", class: "w-10 h-10 rounded-full object-cover shadow-lg border border-white/10" %> -->

        <div class="w-8 h-8 bg-gradient-to-tr from-pink-500 to-violet-600 rounded-full shadow-lg shadow-purple-500/20"></div>

        <h1 class="text-xl font-black tracking-tighter text-white">
          St Lucia
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-blue-400">
            Rentals
          </span>
        </h1>
      </div>

      <!-- NAV LINKS -->
      <div class="hidden md:flex items-center space-x-2">

        <!-- Home -->
        <%= link_to "Home", root_path,
          class: "px-4 py-2 rounded-xl transition-all #{current_page?(root_path) ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-white hover:bg-white/5'}" %>

        <% if user_signed_in? %>

          <% if current_user.owner? %>
            <% [
              ["Dashboard", dashboard_path],
              ["Tenants", v1_tenants_path],
              ["Units", v1_units_path],
              ["Leases", v1_leases_path]
            ].each do |name, path| %>

              <%= link_to name, path,
                class: "px-4 py-2 rounded-xl transition-all #{current_page?(path) ? 'bg-white/10 text-white shadow-inner' : 'text-slate-400 hover:text-white hover:bg-white/5'}" %>

            <% end %>

          <% else %>

            <%= link_to "My Dashboard", tenant_dashboard_index_path,
              class: "px-4 py-2 rounded-xl transition-all #{current_page?(tenant_dashboard_index_path) ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-white hover:bg-white/5'}" %>

          <% end %>

          <!-- Logout -->
          <%= button_to destroy_user_session_path,
              method: :delete,
              class: "ml-4 px-4 py-2 rounded-xl border border-red-500/30 text-red-400 hover:bg-red-500/10 hover:shadow-lg hover:shadow-red-500/10 transition-all duration-200 text-sm font-medium bg-transparent cursor-pointer active:scale-95" do %>
            Logout
          <% end %>

        <% else %>

          <%= link_to "Login",
            new_user_session_path,
            class: "px-4 py-2 text-slate-400 hover:text-white transition" %>

          <%= link_to "Sign Up",
            new_user_registration_path,
            class: "ml-2 px-5 py-2 bg-gradient-to-r from-pink-500 to-violet-600 text-white rounded-xl font-bold shadow-lg shadow-purple-500/20 hover:scale-105 transition active:scale-95" %>

        <% end %>

      </div>
    </nav>

    <!-- FLASH MESSAGES -->
    <div class="max-w-4xl mx-auto mt-6 px-4 space-y-2">

      <% if notice %>
        <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 px-4 py-3 rounded-2xl flex items-center gap-3 backdrop-blur-md">
          <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-rose-500/10 border border-rose-500/20 text-rose-400 px-4 py-3 rounded-2xl flex items-center gap-3 backdrop-blur-md">
          <span class="w-2 h-2 bg-rose-500 rounded-full animate-pulse"></span>
          <%= alert %>
        </div>
      <% end %>

    </div>

    <!-- MAIN CONTENT (FIXED ISSUE HERE) -->
    <main class="max-w-6xl mx-auto mt-8 px-4 pb-12">
      <div class="opacity-100">
        <%= yield %>
      </div>
    </main>

  </body>
</html>