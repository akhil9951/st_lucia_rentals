<!-- 🌟 FEATURES SECTION -->
<div class="bg-white py-12">
  <div class="max-w-6xl mx-auto px-6 text-center">

    <h2 class="text-3xl font-bold text-gray-800 mb-8">
      Why Choose Our Community?
    </h2>

    <div class="grid md:grid-cols-3 gap-6">

      <div class="p-6 rounded-xl shadow">
        <h3 class="font-semibold text-lg mb-2">🏡 Modern Homes</h3>
        <p class="text-gray-500">Spacious houses with premium design</p>
      </div>

      <div class="p-6 rounded-xl shadow">
        <h3 class="font-semibold text-lg mb-2">🌳 Green Environment</h3>
        <p class="text-gray-500">Tree-lined roads and parks</p>
      </div>

      <div class="p-6 rounded-xl shadow">
        <h3 class="font-semibold text-lg mb-2">🛍️ Nearby Shops</h3>
        <p class="text-gray-500">Groceries, salons, and essentials</p>
      </div>

    </div>

  </div>
</div>