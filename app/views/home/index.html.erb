  </h2>

  <!-- GRID -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">

    <!-- 🏠 Houses -->
    <img src="https://images.unsplash.com/photo-1568605114967-8130f3a36994" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">
    <img src="https://images.unsplash.com/photo-1572120360610-d971b9b639c0" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">
    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">
    <img src="https://images.unsplash.com/photo-1580587771525-78b9dba3b914" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">

    <!-- 🌳 Green Areas / Trees -->
    <img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">
    <img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">

    <!-- 🛣️ Roads -->
    <img src="https://images.unsplash.com/photo-1502877338535-766e1452684a" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">
    <img src="https://images.unsplash.com/photo-1500534314209-a25ddb2bd429" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">

    <!-- 🏪 Shops -->
    <img src="https://images.unsplash.com/photo-1528698827591-e19ccd7bc23d" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">
    <img src="https://images.unsplash.com/photo-1521335629791-ce4aec67dd53" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">

    <!-- 🧑‍🤝‍🧑 Lifestyle -->
    <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">
    <img src="https://images.unsplash.com/photo-1492724441997-5dc865305da7" class="rounded-xl shadow hover:scale-105 transition object-cover h-48 w-full">

