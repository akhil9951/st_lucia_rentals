<!-- 🌆 HERO SECTION -->
<div class="relative h-[70vh] flex items-center justify-center text-center text-white">

  <!-- Background -->
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1568605114967-8130f3a36994"
      class="w-full h-full object-cover"
    />
  </div>

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/60"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-2xl px-4">
    <h1 class="text-5xl font-bold mb-4">
      Premium Gated Community Living
    </h1>

    <p class="text-lg mb-8 text-gray-200">
      Modern homes, green spaces, and vibrant neighborhood amenities
    </p>

    <!-- FIXED BUTTON SPACING -->
    <div class="flex justify-center gap-4 flex-wrap">
      <%= link_to "Explore Tenants", v1_tenants_path,
        class: "bg-indigo-600 px-6 py-3 rounded-lg shadow hover:bg-indigo-700 transition" %>

      <%= link_to "Browse Units", v1_units_path,
        class: "bg-white text-gray-800 px-6 py-3 rounded-lg shadow hover:bg-gray-200 transition" %>
    </div>
  </div>
</div>

<!-- 🏡 COMMUNITY GALLERY -->
<div class="max-w-7xl mx-auto px-6 py-12">

  <h2 class="text-3xl font-bold text-gray-800 mb-6 text-center">
